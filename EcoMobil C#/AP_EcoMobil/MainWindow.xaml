<Window x:Class="AP_EcoMobil.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Eco-Mobil - Suivi Direction" Height="700" Width="1100" WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#f4f4f4" Padding="15" BorderBrush="#cccccc" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Agence :" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="Bold"/>
                <ComboBox Width="160" SelectedIndex="0" x:Name="CmbAgences">
                    <ComboBoxItem Content="Consolidée (Groupe)"/>
                    <ComboBoxItem Content="Annecy"/>
                    <ComboBoxItem Content="Grenoble"/>
                    <ComboBoxItem Content="Chambéry"/>
                    <ComboBoxItem Content="Valence"/>
                    <ComboBoxItem Content="Bourg-en-Bresse"/>
                    <ComboBoxItem Content="Saint-Étienne"/>
                </ComboBox>

                <TextBlock Text="Du :" VerticalAlignment="Center" Margin="25,0,10,0"/>
                <DatePicker x:Name="DpDebut" Width="120"/>

                <TextBlock Text="Au :" VerticalAlignment="Center" Margin="20,0,10,0"/>
                <DatePicker x:Name="DpFin" Width="120"/>

                <Button x:Name="BtnActualiser" Content="Actualiser" Width="120" Margin="40,0,0,0" 
                        Background="#28a745" Foreground="White" FontWeight="Bold" Click="BtnActualiser_Click"/>
            </StackPanel>
        </Border>

        <TabControl x:Name="MainTabs" Grid.Row="1" Margin="10">
            <TabItem Header="Quantitatif - Locations">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="{Binding NombreLocations, StringFormat='Nombre total de locations : {0}'}" FontSize="16" FontWeight="Bold" Foreground="#0056b3"/>
                        <TextBlock Text="Répartition par durée :" FontWeight="Bold" Margin="0,15,0,5"/>
                        <DataGrid ItemsSource="{Binding StatsDurees}" AutoGenerateColumns="False" IsReadOnly="True" HorizontalAlignment="Left" Width="400" Height="130">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Durée" Binding="{Binding Duree}" Width="*"/>
                                <DataGridTextColumn Header="Quantité" Binding="{Binding NombreLocations}" Width="80"/>
                                <DataGridTextColumn Header="Part (%)" Binding="{Binding Pourcentage, StringFormat={}{0}%}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="Liste détaillée des réservations :" FontWeight="Bold" Margin="0,20,0,5"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding Reservations}" AutoGenerateColumns="False" IsReadOnly="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                            <DataGridTextColumn Header="Véhicule" Binding="{Binding TypeVehicule}" Width="*"/>
                            <DataGridTextColumn Header="Durée (h)" Binding="{Binding DureeEnHeures}" Width="70"/>
                            <DataGridTextColumn Header="Montant" Binding="{Binding Montant, StringFormat={}{0:F2} €}" Width="80"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding DateLocation, StringFormat=dd/MM/yy HH:mm}" Width="110"/>
                            <DataGridTextColumn Header="Agence" Binding="{Binding Agence}" Width="100"/>
                            <DataGridTextColumn Header="Client" Binding="{Binding Participants}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Financier - Chiffre d'Affaires">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="Chiffre d'Affaires Global :" FontSize="16"/>
                        <TextBlock Text="{Binding ChiffreAffairesTotal, StringFormat={}{0:F2} €}" FontSize="32" FontWeight="Bold" Foreground="#28a745" Margin="0,5,0,25"/>
                        <TextBlock Text="CA par type (Cliquez pour le détail des durées) :" FontWeight="Bold" Margin="0,0,0,5"/>
                    </StackPanel>

                    <DataGrid Grid.Row="1" ItemsSource="{Binding StatsVehicules}" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="DataGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Type" Binding="{Binding TypeVehicule}" Width="*"/>
                            <DataGridTextColumn Header="Nombre" Binding="{Binding NombreLocations}" Width="100"/>
                            <DataGridTextColumn Header="CA total" Binding="{Binding ChiffreAffaires, StringFormat={}{0:F2} €}" Width="120"/>
                            <DataGridTextColumn Header="Part (%)" Binding="{Binding PourcentageCA, StringFormat={}{0}%}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>